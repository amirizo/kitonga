    "payment_flow": {
      "description": "Complete payment process from initiation to internet access",
      "steps": [
        {
          "step": 1,
          "action": "User submits phone number",
          "api": "/initiate-payment/",
          "result": "Payment initiated, USSD sent to phone"
        },
        {
          "step": 2,
          "action": "User completes USSD payment",
          "api": "External (ClickPesa)",
          "result": "Payment processed by mobile money provider"
        },
        {
          "step": 3,
          "action": "ClickPesa sends webhook",
          "api": "/clickpesa-webhook/",
          "result": "Payment marked as completed, access granted"
        },
        {
          "step": 4,
          "action": "User requests verification",
          "api": "/verify/",
          "result": "User connected to internet via MikroTik"
        }
      ]
    },

    "voucher_flow": {
      "description": "Complete voucher redemption process",
      "steps": [
        {
          "step": 1,
          "action": "Admin generates vouchers",
          "api": "/generate-vouchers/",
          "result": "Voucher codes created and sent via SMS"
        },
        {
          "step": 2,
          "action": "User redeems voucher code",
          "api": "/vouchers/redeem/",
          "result": "Voucher validated, access granted, user connected"
        },
        {
          "step": 3,
          "action": "Automatic internet connection",
          "api": "Internal MikroTik integration",
          "result": "User gets immediate internet access"
        }
      ]
    },

