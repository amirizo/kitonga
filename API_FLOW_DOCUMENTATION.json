      "mikrotik_auth": {
        "url": "/mikrotik/auth/",
        "method": "POST",
        "description": "MikroTik hotspot authentication endpoint",
        "authentication": "None required (used by MikroTik router)",
        "request_body": {
          "username": "string (normalized phone number)",
          "password": "string (last 6 digits of phone)"
        },
        "response_examples": {
          "authorized": "OK",
          "denied": {
            "auth-state": 1,
            "error": "User not found or access expired"
          }
        }
      }
    },

    "automatic_systems": {
      "phone_normalization": {
        "description": "Converts all phone number formats to standard 255XXXXXXXXX format",
        "examples": {
          "input": ["+255772236727", "255772236727", "0772236727"],
          "output": "255772236727"
        },
        "prevents_duplicates": "Users with same number in different formats are treated as one user"
      },

      "mikrotik_integration": {
        "description": "Automatic internet connection/disconnection based on access status",
        "connection_triggers": [
          "Successful payment webhook",
          "Voucher redemption",
          "Access verification for valid user"
        ],
        "disconnection_triggers": [
          "Access expiration",
          "Access verification for expired user",
          "Manual admin disconnect"
        ],
        "functions": {
          "grant_user_access": "Creates hotspot user and allows MAC address",
          "revoke_user_access": "Removes hotspot user and blocks MAC address"
        }
      },

      "device_tracking": {
        "description": "Automatic device registration and management",
        "features": [
