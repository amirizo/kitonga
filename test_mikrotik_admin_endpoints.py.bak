#!/usr/bin/env python
"""
Test script for MikroTik Admin Endpoints
Tests all 10 admin-only MikroTik management endpoints according to mikrotik.py configuration
"""

import os
import sys
import django

# Setup Django
os.environ.setdefault('DJANGO_SETTINGS_MODULE', 'kitonga.settings')
django.setup()

from django.test import Client
from django.contrib.auth import get_user_model
from billing.models import User, Bundle, Payment
from django.utils import timezone
from datetime import timedelta
import json

# Test configuration
client = Client()
TEST_PHONE = "+255743852695"

# Get admin token from environment or use the actual token from .env
ADMIN_TOKEN = os.environ.get('ADMIN_TOKEN', 'kitonga_admin_2025')

def print_header(title):
    """Print formatted test header"""
    print("\n" + "="*70)
    print(f"  {title}")
    print("="*70)

def print_result(endpoint, method, status_code, response_data, passed):
    """Print formatted test result"""
    status = "✅ PASS" if passed else "❌ FAIL"
    print(f"\n{status} - {method} {endpoint}")
    print(f"Status Code: {status_code}")
    if isinstance(response_data, dict):
        print(f"Response: {json.dumps(response_data, indent=2)}")
    else:
        print(f"Response: {response_data[:500]}")  # Truncate long responses

def setup_test_user():
    """Create or get test user with active access"""
    print_header("Setting up test user")
    
    user, created = User.objects.get_or_create(
        phone_number=TEST_PHONE,
        defaults={
            'is_active': True,
            'paid_until': timezone.now() + timedelta(hours=24),
            'max_devices': 3
        }
    )
    
    if not created:
        user.is_active = True
        user.paid_until = timezone.now() + timedelta(hours=24)
        user.save()
    
    bundle, _ = Bundle.objects.get_or_create(
        name='Test Bundle',
        defaults={
            'price': 1000,
            'duration_hours': 24,
            'is_active': True
        }
    )
    
    if not user.payments.filter(status='completed').exists():
        import uuid
        Payment.objects.create(
            user=user,
            bundle=bundle,
            amount=bundle.price,
            status='completed',
            phone_number=TEST_PHONE,
            transaction_id=f'TEST-{uuid.uuid4().hex[:12]}',
            order_reference=f'ORD-{uuid.uuid4().hex[:12]}'
        )
    
    print(f"✅ Test user ready: {TEST_PHONE}")
    return user

def test_mikrotik_configuration():
    """Test 1: GET MikroTik Configuration"""
    print_header("Test 1: MikroTik Config - GET /api/admin/mikrotik/config/")
    
    response = client.get('/api/admin/mikrotik/config/', 
                         HTTP_X_ADMIN_ACCESS=ADMIN_TOKEN)
    
    try:
        data = response.json()
        passed = response.status_code == 200 and data.get('success') == True
        print_result('/api/admin/mikrotik/config/', 'GET', response.status_code, data, passed)
        return passed
    except:
        passed = False
        print_result('/api/admin/mikrotik/config/', 'GET', response.status_code, 
                     response.content.decode(), passed)
        return passed

def test_test_connection():
    """Test 2: Test MikroTik Connection"""
    print_header("Test 2: Test Connection - GET /api/admin/mikrotik/test-connection/")
    
    response = client.get('/api/admin/mikrotik/test-connection/', 
                         HTTP_X_ADMIN_TOKEN=ADMIN_TOKEN)
    
    try:
        data = response.json()
        passed = response.status_code == 200 and data.get('success') == True
        print_result('/api/admin/mikrotik/test-connection/', 'GET', response.status_code, data, passed)
        return passed
    except:
        passed = False
        print_result('/api/admin/mikrotik/test-connection/', 'GET', response.status_code, 
                     response.content.decode(), passed)
        return passed

