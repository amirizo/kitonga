def test_disconnect_user():
    """Test 5: Disconnect Specific User"""
    print_header("Test 5: Disconnect User - POST /api/admin/mikrotik/disconnect-user/")
    
    response = client.post('/api/admin/mikrotik/disconnect-user/',
        json.dumps({'phone_number': TEST_PHONE}),
        content_type='application/json',
        HTTP_X_ADMIN_TOKEN=ADMIN_TOKEN
    )
    
    try:
        data = response.json()
        # This might return success even if user not connected - that's OK
        passed = response.status_code in [200, 404] and data.get('success') in [True, False]
        print_result('/api/admin/mikrotik/disconnect-user/', 'POST', response.status_code, data, passed)
        return passed
    except:
        passed = False
        print_result('/api/admin/mikrotik/disconnect-user/', 'POST', response.status_code, 
                     response.content.decode(), passed)
        return passed

