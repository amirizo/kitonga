def test_create_profile():
    """Test 9: Create Hotspot Profile"""
    print_header("Test 9: Create Profile - POST /api/admin/mikrotik/profiles/create/")
    
    response = client.post('/api/admin/mikrotik/profiles/create/',
        json.dumps({
            'name': 'test-profile',
            'rate_limit': '1M/1M',
            'session_timeout': '1d',
            'idle_timeout': '5m'
        }),
        content_type='application/json',
        HTTP_X_ADMIN_TOKEN=ADMIN_TOKEN
    )
    
    try:
        data = response.json()
        # May fail if profile exists - that's OK
        passed = response.status_code in [200, 201, 400] and 'success' in data
        print_result('/api/admin/mikrotik/profiles/create/', 'POST', response.status_code, data, passed)
        return passed
    except:
        passed = False
        print_result('/api/admin/mikrotik/profiles/create/', 'POST', response.status_code, 
                     response.content.decode(), passed)
        return passed

