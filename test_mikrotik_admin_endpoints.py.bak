    """Test 6: Disconnect All Users"""
    print_header("Test 6: Disconnect All - POST /api/admin/mikrotik/disconnect-all/")
    
    response = client.post('/api/admin/mikrotik/disconnect-all/',
        content_type='application/json',
        HTTP_X_ADMIN_TOKEN=ADMIN_TOKEN
    )
    
    try:
        data = response.json()
