    """Test 4: Get Active Hotspot Users"""
    print_header("Test 4: Active Users - GET /api/admin/mikrotik/active-users/")
    
    response = client.get('/api/admin/mikrotik/active-users/', 
                         HTTP_X_ADMIN_TOKEN=ADMIN_TOKEN)
    
    try:
        data = response.json()
        passed = response.status_code == 200 and data.get('success') == True
        print_result('/api/admin/mikrotik/active-users/', 'GET', response.status_code, data, passed)
