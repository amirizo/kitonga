def test_auth_required():
    """Bonus Test: Verify Admin Auth is Required"""
    print_header("Bonus Test: Admin Authentication Required")
    
    print("\n--- Testing without admin token ---")
    response = client.get('/api/admin/mikrotik/config/')
    
    passed = response.status_code in [401, 403]
    try:
        data = response.json()
        print_result('/api/admin/mikrotik/config/', 'GET (no auth)', response.status_code, data, passed)
    except:
        print_result('/api/admin/mikrotik/config/', 'GET (no auth)', response.status_code, 
                     response.content.decode(), passed)
    
    return passed

def main():
    """Run all tests"""
    print("\n" + "🔧 " * 35)
    print("  MIKROTIK ADMIN ENDPOINTS TEST SUITE")
    print("  Testing 10 Admin-Only MikroTik Management Endpoints")
    print("🔧 " * 35)
    
    try:
        # Setup
        user = setup_test_user()
        
        # Run tests
        tests = [
            ("MikroTik Configuration", test_mikrotik_configuration),
            ("Test Connection", test_test_connection),
            ("Router Info", test_router_info),
            ("Active Users", test_active_users),
            ("Disconnect User", test_disconnect_user),
            ("Disconnect All Users", test_disconnect_all),
            ("Reboot Router", test_reboot_router),
            ("Hotspot Profiles", test_hotspot_profiles),
            ("Create Profile", test_create_profile),
            ("System Resources", test_system_resources),
            ("Admin Auth Required", test_auth_required),
        ]
        
        results = []
        for test_name, test_func in tests:
            try:
                success = test_func()
                results.append((test_name, success))
            except Exception as e:
                print(f"\n❌ ERROR in {test_name}: {str(e)}")
                import traceback
                traceback.print_exc()
                results.append((test_name, False))
        
        # Print summary
        print_header("TEST SUMMARY")
        passed = sum(1 for _, success in results if success)
        total = len(results)
        
        for test_name, success in results:
            status = "✅ PASS" if success else "❌ FAIL"
            print(f"{status} - {test_name}")
        
        print(f"\n{'='*70}")
        print(f"Total: {passed}/{total} tests passed ({passed*100//total}%)")
        print(f"{'='*70}")
        
        if passed == total:
            print("\n🎉 ALL MIKROTIK ADMIN ENDPOINTS ARE WORKING!")
            print("\nEndpoint Summary:")
            print("1. ✅ GET /api/admin/mikrotik/config/ - Get MikroTik configuration")
            print("2. ✅ GET /api/admin/mikrotik/test-connection/ - Test router connection")
            print("3. ✅ GET /api/admin/mikrotik/router-info/ - Get router information")
            print("4. ✅ GET /api/admin/mikrotik/active-users/ - Get active hotspot users")
            print("5. ✅ POST /api/admin/mikrotik/disconnect-user/ - Disconnect specific user")
            print("6. ✅ POST /api/admin/mikrotik/disconnect-all/ - Disconnect all users")
            print("7. ✅ POST /api/admin/mikrotik/reboot/ - Reboot router")
            print("8. ✅ GET /api/admin/mikrotik/profiles/ - Get hotspot profiles")
            print("9. ✅ POST /api/admin/mikrotik/profiles/create/ - Create hotspot profile")
            print("10. ✅ GET /api/admin/mikrotik/resources/ - Get system resources")
            print("\n✅ Admin authentication properly enforced (X-Admin-Token required)")
            print("\nAll endpoints aligned with mikrotik.py functions:")
            print("- test_mikrotik_connection()")
            print("- get_router_info()")
            print("- get_active_hotspot_users()")
            print("- disconnect_all_hotspot_users()")
            print("- reboot_router()")
            print("- get_hotspot_profiles()")
            print("- create_hotspot_profile()")
        else:
            print(f"\n⚠️  {total - passed} test(s) failed. Please review the errors above.")
        
        return passed == total
        
    except Exception as e:
        print(f"\n❌ FATAL ERROR: {str(e)}")
        import traceback
        traceback.print_exc()
        return False

if __name__ == '__main__':
    success = main()
    sys.exit(0 if success else 1)
