def test_reboot_router():
    """Test 7: Reboot Router (Dry Run - Won't Actually Reboot)"""
    print_header("Test 7: Reboot Router - POST /api/admin/mikrotik/reboot/")
    
    print("⚠️  Note: This test will NOT actually reboot the router")
    print("    It will only test if the endpoint responds correctly")
    
    # We'll test the endpoint exists and requires auth, but won't actually reboot
    response = client.post('/api/admin/mikrotik/reboot/',
        json.dumps({'confirm': False}),  # Don't actually reboot
        content_type='application/json',
        HTTP_X_ADMIN_TOKEN=ADMIN_TOKEN
    )
    
    try:
        data = response.json()
        # Accept success or confirmation required response
        passed = response.status_code in [200, 400] and 'success' in data
        print_result('/api/admin/mikrotik/reboot/', 'POST', response.status_code, data, passed)
        return passed
    except:
        passed = False
        print_result('/api/admin/mikrotik/reboot/', 'POST', response.status_code, 
                     response.content.decode(), passed)
        return passed

