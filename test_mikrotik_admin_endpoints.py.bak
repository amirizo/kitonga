    """Test 10: Get System Resources"""
    print_header("Test 10: System Resources - GET /api/admin/mikrotik/resources/")
    
    response = client.get('/api/admin/mikrotik/resources/', 
                         HTTP_X_ADMIN_TOKEN=ADMIN_TOKEN)
    
    try:
